# ── HOW TO USE THIS FILE ─────────────────────────────────────────────────────
# Copy this file to .env and fill in all empty values before running locally.
# Never commit .env to version control.
# On AWS, all secrets are managed via SSM Parameter Store — see infra/deploy.sh.
# ─────────────────────────────────────────────────────────────────────────────

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
# Your 12-digit AWS account ID — required for deploy.sh and ECR image URIs
AWS_ACCOUNT_ID=
S3_BUCKET=myntist-beacon-feeds
# Set CANONICAL_URL to the live endpoint URL so status.json advertises the
# correct address. Example: https://myntist.com/api/field/v1/status.json
# This MUST be set when deploying to AWS — without it, status.json will report
# https://myntist.com even when running on a different host.
CANONICAL_URL=
CLOUDFRONT_DOMAIN=https://myntist.com

# ── Ed25519 Signing ──────────────────────────────────────────────────────────
# Hex-encoded 32-byte Ed25519 private key. Required for signed status.json.
# Generate with: python -c "from cryptography.hazmat.primitives.asymmetric.ed25519 import Ed25519PrivateKey; import binascii; k = Ed25519PrivateKey.generate(); print(binascii.hexlify(k.private_bytes_raw()).decode())"
ED25519_PRIVATE_KEY_HEX=
ED25519_KEY_CREATED=

# ── KMS Signing (production alternative to Ed25519) ──────────────────────────
# Set KMS_KEY_ID to a real key ARN (not an alias) to use AWS KMS RSA-PSS signing.
# Note: KMS uses RSASSA_PSS_SHA_256 — this is different from Ed25519.
# If ED25519_PRIVATE_KEY_HEX is set, it takes priority over KMS.
KMS_KEY_ID=

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://myntist:myntist@localhost:5432/iam_substrate
TIMESCALEDB_URL=postgresql://myntist:myntist@timescaledb:5432/iam_substrate
TIMESCALEDB_HYPERTABLE_CHUNK_INTERVAL=7days

# ── Telemetry & Audit ─────────────────────────────────────────────────────────
# How many hours of telemetry history to keep for the /telemetry/historical endpoint.
# Default 720 (30 days). Set TELEMETRY_RETENTION_HOURS (in role_decay.py) separately.
TELEMETRY_WINDOW_HOURS=720

# ── IAM Substrate ─────────────────────────────────────────────────────────────
SUBSTRATE_API_URL=http://localhost:8000
SUBSTRATE_API_KEY=
SUBSTRATE_HMAC_SECRET=
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=myntist
KEYCLOAK_CLIENT_ID=substrate-client
KEYCLOAK_CLIENT_SECRET=
ADMIN_API_KEY=

# ── GoDaddy DNS Anchoring ─────────────────────────────────────────────────────
# All 4 TXT records (_s.v1, _buoy.latest, _ledger.anchor, _float.audit) are
# updated automatically when GODADDY_API_KEY is set.
GODADDY_API_KEY=
GODADDY_API_SECRET=
GODADDY_DOMAIN=myntist.com
# Set ENABLE_DNS_UPDATE=false to disable DNS anchoring in non-production environments
ENABLE_DNS_UPDATE=true
# Set ENABLE_LEDGER_ANCHOR=false to skip IPFS/Zenodo anchoring (_ledger.anchor)
ENABLE_LEDGER_ANCHOR=true

# ── IPFS (Pinata) ─────────────────────────────────────────────────────────────
IPFS_API_URL=https://api.pinata.cloud
IPFS_API_KEY=
IPFS_API_SECRET=

# ── Zenodo ────────────────────────────────────────────────────────────────────
ZENODO_API_KEY=
# Set to true for sandbox testing, false for production deposits
ZENODO_SANDBOX=false

# ── Lens ──────────────────────────────────────────────────────────────────────
LENS_PROFILE_ID=
LENS_ACCESS_TOKEN=

# ── Farcaster ─────────────────────────────────────────────────────────────────
FARCASTER_FID=
FARCASTER_HUB_URL=https://hub.farcaster.xyz:2281
FARCASTER_SIGNER_UUID=

# ── GitHub Autoheal ───────────────────────────────────────────────────────────
# All four vars are required for the autoheal function to open real GitHub PRs.
# GH_APP_ID:              numeric GitHub App ID
# GH_APP_PRIVATE_KEY:     PEM-encoded private key for the GitHub App
# GH_APP_INSTALLATION_ID: installation ID for the app on the target repository
# GH_APP_REPO:            target repository in "org/repo" format
GH_APP_ID=
GH_APP_PRIVATE_KEY=
GH_APP_INSTALLATION_ID=
GH_APP_REPO=

# ── Slack ─────────────────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=
SLACK_CHANNEL=#myntist-beacon-alerts

# ── Container Registry ────────────────────────────────────────────────────────
GHCR_USERNAME=
GHCR_TOKEN=

# ── Phase 2 Feature Flags ─────────────────────────────────────────────────────
ENABLE_FLOAT_ANALYTICS=true
ENABLE_EVENT_BUS=false
IFRS_BRIDGE_ENABLED=false
ENABLE_ROS=false
ENABLE_ROS_AGENTS=false
ENABLE_UPLIFT_HARVESTER=false
ENABLE_GOVERNANCE_SDK=false

# ── Phase 2 Financial Engine ──────────────────────────────────────────────────
OPEX_BASELINE_USD=500.00
FLOAT_REINVESTMENT_RATE=0.63
R_HSCE_SMOOTHING_WINDOW=7
PARQUET_EXPORT_ENABLED=true

# ── HSCE ──────────────────────────────────────────────────────────────────────
HSCE_ENDPOINT=
HSCE_API_TOKEN=
HSCE_PUSH_TIMEOUT=10

# ── Policy Engine ─────────────────────────────────────────────────────────────
POLICY_ENGINE_ENABLED=true
TTAU_BREACH_RESET_THRESHOLD=0.25

# ── Monitoring ────────────────────────────────────────────────────────────────
GRAFANA_API_KEY=
GRAFANA_URL=http://localhost:3000
